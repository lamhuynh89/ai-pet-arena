STORAGE_MODE=mock
# PRIVATE_KEY=0x...   # ONLY for real 0G Storage/Compute. NEVER commit. Testnet only.
OG_NETWORK=testnet
PORT=3002

# AI control
AI_MODE=mock          # mock | 0g   (0g = use real 0G Compute inference)

# === REAL 0G SETUP (Storage + Compute) ===
# 1. Get testnet OG (need >=3 OG for ledger):
#    https://faucet.0g.ai   OR   https://cloud.google.com/application/web3/faucet/0g/galileo
# 2. Set STORAGE_MODE=real + AI_MODE=0g
# 3. Put PRIVATE_KEY
# 4. RUN SETUP (fixes "Sub-account not found" / Account does not exist):
#    cd backend
#    node scripts/setup-0g-compute.js
#    See full guide: ../0G_COMPUTE_SETUP.md
# 5. npm run dev   (or STORAGE_MODE=real AI_MODE=0g node smoke-0g.js)
#
# What setup does:
# - addLedger (create main account, min 3 OG)
# - depositFund
# - transfer-fund to provider (creates sub-account)
# - acknowledgeProvider
#
# CLI alternative (after npm i -g or npx):
#   0g-compute-cli add-account --amount 3
#   0g-compute-cli deposit --amount 1
#   0g-compute-cli transfer-fund --provider <ADDR> --amount 0.5 --service inference
#
# Get testnet: https://faucet.0g.ai | explorer: https://chainscan-galileo.0g.ai
# WARNING: Real mode spends gas on every create/action/chat